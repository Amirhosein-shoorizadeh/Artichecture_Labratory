library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity Multiplier_4x4_CLA_tb is
end Multiplier_4x4_CLA_tb;

architecture Behavioral of Multiplier_4x4_CLA_tb is

    component Multiplier_4x4_CLA is
        Port ( X : in  STD_LOGIC_VECTOR (3 downto 0);
               Y : in  STD_LOGIC_VECTOR (3 downto 0);
               P : out STD_LOGIC_VECTOR (7 downto 0)
             );
    end component;

    signal X_tb : STD_LOGIC_VECTOR (3 downto 0);
    signal Y_tb : STD_LOGIC_VECTOR (3 downto 0);
    signal P_tb : STD_LOGIC_VECTOR (7 downto 0);

begin

    UUT: Multiplier_4x4_CLA port map (X => X_tb, Y => Y_tb, P => P_tb);

    process
    begin
        -- 3 * 5 = 15
        X_tb <= "0011";  Y_tb <= "0101";
        wait for 10 ns;
        
        --  7 * 2 = 14
        X_tb <= "0111";  Y_tb <= "0010";
        wait for 10 ns;
        
        -- 15 * 15 = 225
        X_tb <= "1111";  Y_tb <= "1111";
        wait for 10 ns;
        
        -- 0 * 8 = 0
        X_tb <= "0000";  Y_tb <= "1000";
        wait for 10 ns;
        
        -- 10 * 10 = 100
        X_tb <= "1010";  Y_tb <= "1010";
        wait for 10 ns;
        
        
        wait;
    end process;

end Behavioral;
