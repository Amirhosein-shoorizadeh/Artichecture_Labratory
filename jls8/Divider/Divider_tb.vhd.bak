library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity tb_divider is
end tb_divider;

architecture sim of tb_divider is

    signal clk : std_logic := '0';
    signal start : std_logic := '0';

    signal A_in : std_logic_vector(7 downto 0);
    signal B_in : std_logic_vector(3 downto 0);

    signal quotient : std_logic_vector(7 downto 0);
    signal remainder : std_logic_vector(4 downto 0);
    signal done : std_logic;

begin

    uut: entity work.divider_8by4
    port map(
        clk => clk,
        start => start,
        A_in => A_in,
        B_in => B_in,
        quotient => quotient,
        remainder => remainder,
        done => done
    );

    clk <= not clk after 10 ns;

    process
    begin

        -- 100 / 5 = 20
        A_in <= "01100100";
        B_in <= "0101";

        start <= '1';
        wait for 20 ns;
        start <= '0';

        wait until done='1';

        wait for 40 ns;

        -- 75 / 3 = 25
        A_in <= "01001011";
        B_in <= "0011";

        start <= '1';
        wait for 20 ns;
        start <= '0';

        wait until done='1';

        wait;

    end process;

end sim;
